# ============================================
# DSA-HK: HK Stock Daily Analysis
# Copy this file to .env and fill in your keys
# ============================================

# ---- LLM (pick at least one) ----
# MiniMax (https://api.minimax.io) — OpenAI-compatible
# Get key from https://api.minimax.io → API Keys
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
# Model: M2.7 (default) or M2.7-highspeed (faster, slightly cheaper)
MINIMAX_MODEL=MiniMax-M2.7

# Gemini (free tier OK): https://aistudio.google.com
GEMINI_API_KEY=
# DeepSeek (cheap, good for Chinese): https://platform.deepseek.com
DEEPSEEK_API_KEY=
# OpenAI: https://platform.openai.com
OPENAI_API_KEY=
# OpenAI-compatible base URL (for proxies / alternative providers)
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat

# Default model used by analyzer.
# If you set MINIMAX_API_KEY and no other key, this auto-defaults to openai/MiniMax-M2.7.
# Examples:
#   openai/MiniMax-M2.7            (MiniMax, recommended for HK 中文)
#   openai/MiniMax-M2.7-highspeed  (MiniMax, faster)
#   gemini/gemini-2.5-flash        (free, fast)
#   gemini/gemini-2.5-pro           (smarter)
#   deepseek/deepseek-chat          (cheap, good 中文)
#   gpt-4o-mini                     (cheap OpenAI)
#   openai/gpt-4o                   (best, pricey)
LITELLM_MODEL=openai/MiniMax-M2.7

# Report output language: zh-Hant (繁體中文, default) | en (English)
REPORT_LANGUAGE=zh-Hant

# ---- HK Data Sources ----
# Futu OpenD (primary) — must be running locally
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
# YFinance used as automatic fallback if Futu unavailable

# ---- News Search (pick at least one) ----
# Tavily: https://tavily.com (1000 free/month, English-optimized)
TAVILY_API_KEY=
# Bocha: https://open.bocha.cn (Chinese-optimized)
BOCHA_API_KEY=
# Brave Search: https://brave.com/search/api (English)
BRAVE_API_KEY=

# ---- Ticker Universe ----
# Path to the curated radar JSON. HK tickers are extracted automatically.
# Default: your existing trading-platform curated radar
RADAR_PATH=/Users/kenken/Documents/Gstack/trading-platform/docs/curated-radar.json
# Optional override: comma-separated list of HK tickers (skips radar file)
# HK_TICKERS_OVERRIDE=0700.HK,9988.HK,1810.HK
# Limit to first N HK tickers from radar (0 = all 44)
MAX_TICKERS=0

# ---- Telegram Bot (optional but recommended) ----
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal chat ID (or group ID). Send /start to @userinfobot to find it.
TELEGRAM_CHAT_ID=
# Topic ID for threaded groups (optional)
# TELEGRAM_MESSAGE_THREAD_ID=

# ---- Storage ----
DATABASE_PATH=./data/dsa_hk.db
REPORTS_DIR=./reports
LOG_DIR=./logs

# ---- Scheduler ----
# Run daily at this time (HKT). 18:00 = right after HK market close
SCHEDULE_TIME=18:00
# Enable scheduler (true/false). If false, run manually with: python -m src.main analyze
SCHEDULE_ENABLED=true
# Skip weekends + HK public holidays (basic check)
SKIP_NON_TRADING_DAYS=true

# ---- Server ----
WEBUI_PORT=8200
LOG_LEVEL=INFO
